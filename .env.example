# Bank Reconciliation SaaS — Environment
# Copy to .env and fill values for production

# ============ REQUIRED FOR PRODUCTION ============
# JWT_SECRET must be a strong, unique value (min 32 chars). App will not start without it.
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend URL(s) for CORS. Comma-separated for multiple origins.
# Example: https://app.yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=

# Database
DATABASE_URL=postgresql://user:password@host:5432/brs_db

# ============ API ============
NODE_ENV=production
PORT=9001

# ============ FRONTEND (for local dev) ============
# VITE_API_URL=http://localhost:9001

# ============ FILE UPLOAD ============
# Directory for uploads (default: ./uploads)
UPLOAD_DIR=./uploads
# Max document size in MB (default: 10)
MAX_UPLOAD_SIZE_MB=10

# ============ BASE URL ============
# Used for logo URLs, reset links, etc. Example: https://api.yourdomain.com
API_BASE_URL=

# ============ EMAIL (Resend — for password reset) ============
# APP_URL=https://kqsoftwaresolutions.com
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=BRS <noreply@yourdomain.com>

# ============ PLATFORM ADMIN ============
# Comma-separated emails with full platform access
# PLATFORM_ADMIN_EMAILS=admin@kqsoftwaresolutions.com,admin@qsoft.com

# ============ PAYSTACK (Ghana billing) ============
# PAYSTACK_SECRET_KEY=sk_live_xxx
# PAYSTACK_WEBHOOK_SECRET=whsec_xxx
# Configure webhook in Paystack: https://api.yourdomain.com/api/v1/subscription/webhook

# ============ API (production Docker entrypoint) ============
# Empty DB bootstrap: db push + mark migrations applied when "projects" table is missing (see api/start-api.sh).
# Set to 0 if you manage schema only via SQL / external baseline.
# PRISMA_BOOTSTRAP_EMPTY_DB=1
#
# Comma-separated Prisma migration names to auto-resolve as rolled-back when deploy hits P3009 (see api/start-api.sh).
# Leave unset for default (20250228140000_add_project_slug). Set empty to disable.
# PRISMA_AUTO_RESOLVE_MIGRATIONS=

# ============ DOCKER COMPOSE (optional override) ============
# Production compose does not publish api/web to the host (Coolify-safe).
# For local ports, use docker-compose.override.example.yml → docker-compose.override.yml
# WEB_PORT=8080
# API_PORT=9001

# ============ OPTIONAL ============
# REDIS_URL=redis://localhost:6379
# PDF_USE_NATIVE_FIRST=true
# PDF_OCR_MAX_PAGES=50
# PDF_OCR_SCALE=2
# OCR_LANG=eng
# OCR_LANGS=eng,fra
