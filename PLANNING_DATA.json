  "technical_stack": {
    "frontend": ["react_18", "typescript", "tailwind_css", "zustand", "tanstack_query"],
    "backend": ["node_express_or_fastapi"],
    "database": "postgresql",
    "cache": "redis",
    "queue": "bull",
    "storage": "minio_s3",
    "ocr": ["tesseract", "azure_document_intelligence_optional"],
    "auth": ["jwt", "refresh_tokens"],
    "payments": "paystack_ghs"
  },

  "development_phases": [
    {
      "phase": 1,
      "name": "Foundation",
      "weeks": "1-4",
      "tasks": ["repo_setup", "docker_compose", "auth", "user_org_models", "document_upload", "column_mapping", "schema_validation"]
    },
    {
      "phase": 2,
      "name": "Core Engine",
      "weeks": "5-8",
      "tasks": ["parsers_excel_csv_pdf_ocr", "matching_engine_1to1", "side_by_side_view", "suggested_matches", "brs_report", "basic_branding"]
    },
    {
      "phase": 3,
      "name": "Advanced Matching",
      "weeks": "9-12",
      "tasks": ["one_to_many_many_to_many", "bank_rules_engine", "bulk_match_50", "reference_extraction", "exception_flagging", "reopen_periods", "audit_trail", "discrepancy_missing_cheques_reports", "roll_forward"]
    },
    {
      "phase": 4,
      "name": "AI & Automation",
      "weeks": "13-16",
      "tasks": ["ai_suggested_matches", "learning_from_corrections", "bank_rules_ui", "threshold_approval", "auto_journal_suggestions", "ghana_bank_parsers"]
    },
    {
      "phase": 5,
      "name": "SaaS & Polish",
      "weeks": "17-20",
      "tasks": ["subscription_tiers", "paystack_integration", "usage_tracking", "limits_enforcement", "firm_dashboard", "audit_trail_ui", "white_label_branding", "intro_offer"]
    },
    {
      "phase": 6,
      "name": "Launch",
      "weeks": "21-22",
      "tasks": ["e2e_testing", "performance_tuning", "documentation", "coolify_deployment", "monitoring_alerts"]
    }
  ],

  "acceptance_criteria": [
    "upload_cash_book_bank_statement_excel_csv_pdf_image",
