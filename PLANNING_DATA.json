  "promotions": {
    "intro_offer": {
      "description": "50% off first 2 months",
      "discount_percent": 50,
      "duration_months": 2,
      "eligible": "new_customers"
    },
    "annual_tiered": {
      "12_months": 15,
      "24_months": 20,
      "36_months": 25
    }
  },

  "canonical_schemas": {
    "cash_book_receipts": {
      "fields": [
        {"name": "s_no", "type": "integer", "required": false},
        {"name": "date", "type": "date", "required": true},
        {"name": "name", "type": "string", "required": false},
        {"name": "details", "type": "string", "required": true},
        {"name": "doc_ref", "type": "string", "required": false},
        {"name": "chq_no", "type": "string", "required": false},
        {"name": "accode", "type": "integer", "required": false},
        {"name": "amt_received", "type": "decimal", "required": true, "precision": 18, "scale": 2}
      ]
    },
    "cash_book_payments": {
      "fields": [
        {"name": "s_no", "type": "integer", "required": false},
        {"name": "date", "type": "date", "required": true},
        {"name": "name", "type": "string", "required": false},
        {"name": "details", "type": "string", "required": true},
        {"name": "doc_ref", "type": "string", "required": false},
        {"name": "chq_no", "type": "string", "required": false},
        {"name": "accode", "type": "integer", "required": false},
        {"name": "amt_paid", "type": "decimal", "required": true, "precision": 18, "scale": 2}
      ]
    },
    "bank_statement_credits": {
      "fields": [
        {"name": "transaction_date", "type": "date", "required": true},
        {"name": "description", "type": "string", "required": true},
        {"name": "credit", "type": "decimal", "required": true, "precision": 18, "scale": 2}
      ]
    },
    "bank_statement_debits": {
      "fields": [
        {"name": "transaction_date", "type": "date", "required": true},
        {"name": "description", "type": "string", "required": true},
        {"name": "debit", "type": "decimal", "required": true, "precision": 18, "scale": 2}
      ]
    }
  },

  "matching_engine": {
    "rules_priority": ["exact_match", "amount_date_window", "amount_description_similarity", "reference_extraction", "bank_rules"],
    "parameters": {
      "amount_tolerance": 0.01,
      "amount_tolerance_unit": "GHS",
      "date_window_days": 3,
      "description_similarity_threshold": 0.7,
      "bulk_match_limit": 50
    },
    "match_types": ["one_to_one", "one_to_many", "many_to_one", "many_to_many"],
    "exception_handling": ["flag_unmatched_cash_book", "flag_unmatched_bank", "flag_low_confidence", "detect_duplicates", "variance_analysis"]
  },

  "bank_rules_engine": {
    "condition_operators": ["equals", "contains", "starts_with", "regex", "gt", "gte", "lt", "lte", "between"],
    "actions": ["match_to_account", "suggest_match", "auto_approve", "flag_for_review"],
    "prioritization": "user_defined_integer"
  },

  "report_sections": [
    "header",
    "closing_balance_per_bank_statement",
    "uncredited_lodgments",
    "unmatched_receipts_in_cash_book",
    "unmatched_credits_in_bank_statement",
    "unpresented_cheques",
    "unmatched_payments_in_cash_book",
    "balance_per_cash_book_at_end_of_period",
    "adjusted_bank_balance",
    "adjusted_cash_book_balance",
    "reconciled_balance",
    "sign_off"
  ],

  "competitor_feature_matrix": {
    "quickbooks": ["tiered_plans", "usage_limits", "discrepancy_report", "missing_cheques_report", "accountant_view"],
    "xero": ["bank_rules", "bulk_match", "suggested_matches", "jax_ai_beta", "reopen_periods"],
    "sage_intacct": ["matching_rules", "creation_rules", "rule_prioritization", "reopenable_periods", "threshold_approval"],
    "zoho_books": ["ai_field_prediction", "bulk_categorization_50", "centralized_rules", "filter_by_amount_date"],
    "blackline": ["exception_flagging", "threshold_approval", "verity_ai", "transaction_matching_millions"],
    "wave": ["free_tier", "simple_ux", "receipt_ocr_pro"],
    "netsuite": ["intelligent_matching", "side_by_side_grids", "system_user_rules", "erp_integration"],
    "q_soft_adoption": "all_above_closed"
  },

